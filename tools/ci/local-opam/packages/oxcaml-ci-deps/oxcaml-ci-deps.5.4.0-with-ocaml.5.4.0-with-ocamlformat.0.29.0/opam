# The package name and version match oxcaml's oxcaml-ci-deps so that the
# `Set up Opam` workflow step stays byte-identical to oxcaml's. The
# dependencies are trimmed to just a stock compiler: the mock build only
# needs ocamlopt (so the version string's mention of ocamlformat is a lie).
depends: [
  "ocaml-base-compiler" {= "5.4.0"}
]
build: []
install: []
